/**index.wxss**/

/* 主体内容区域 */
.main-content {
  padding: 0 30rpx;
  margin-top: -30rpx;
}

.service-grid {
  margin-bottom: 30rpx;
}

/* 卡片整体样式 */
.card {
  display: flex;
  align-items: center;
  background-color: white;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 16rpx rgba(0,0,0,0.04);
  transition: all 0.2s;
}

/* 特殊的 SOS 卡片样式 */
.sos-card {
  border: 2rpx solid #ffe3e3;
  background: linear-gradient(to right, #fff, #fffcfc);
}

.card-icon {
  font-size: 60rpx;
  margin-right: 30rpx;
}

.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.card-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.sos-card .card-name {
  color: #e74c3c;
}

.card-desc {
  font-size: 26rpx;
  color: #999;
}

.arrow {
  color: #ccc;
  font-weight: bold;
  font-size: 32rpx;
}

/* 特殊卡片样式 */
.login-card .card-icon {
  font-size: 50rpx;
}

.bind-card .card-icon {
  font-size: 50rpx;
}

.user-card .card-icon {
  font-size: 50rpx;
}

/* 卡片内的按钮 */
.card .btn {
  min-width: 120rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 26rpx;
  padding: 0 20rpx;
}
