<!-- pages/index/index.wxml -->
<navigation-bar title="邻智灵" back="{{false}}" color="black" background="#FFF"></navigation-bar>
<view class="page">
  <view class="wrap">
    <view class="card hero">
      <view class="section-title">社区便民服务</view>
      <view class="muted">报修闭环 · 邻里互助 · 一键求助 · 公告触达</view>
      <view class="row hero-actions" wx:if="{{authed}}">
        <button class="btn btn-primary" size="mini" bindtap="goRepair">去报修</button>
        <button class="btn" size="mini" bindtap="goHelp">去互助</button>
        <button class="btn" size="mini" bindtap="goNotices">看公告</button>
      </view>
      <button wx:if="{{!authed}}" class="btn-primary auth" bindtap="wxLogin">微信一键授权登录</button>
    </view>

    <view class="card quick">
      <view class="row">
        <view class="col">
          <view class="section-title">一键紧急求助</view>
          <view class="muted">会记录定位并通知物业/网格员</view>
        </view>
        <button class="btn btn-danger" bindtap="sos">求助</button>
      </view>
    </view>

    <view class="card">
      <view class="row">
        <view class="section-title">我的身份</view>
        <view class="tag">{{roleText}}</view>
      </view>
      <view class="muted" wx:if="{{boundCount>0}}">已绑定 {{boundCount}} 套房屋</view>
      <view class="muted" wx:else>未绑定房屋，将无法使用报修/公告/互助等功能</view>
      <button class="btn" size="mini" bindtap="goBind">去绑定房屋</button>
    </view>
  </view>
</view>
