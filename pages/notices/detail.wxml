<navigation-bar title="公告详情" back="{{true}}" color="black" background="#FFF"></navigation-bar>
<view class="page">
  <view class="wrap" wx:if="{{notice}}">
    <view class="card">
      <view class="section-title">{{notice.title}}</view>
      <view class="muted mt">{{notice.type}} · {{format(notice.createdAt)}} <text wx:if="{{read}}">· 已读</text></view>
      <view class="content mt">{{notice.content}}</view>
    </view>

    <view class="card" wx:if="{{isStaff}}">
      <view class="row">
        <view class="section-title">触达统计</view>
        <button size="mini" bindtap="loadStats">刷新</button>
      </view>
      <view class="muted mt">已读：{{stats.readUsers}} / {{stats.totalUsers}}</view>
    </view>
  </view>

  <view class="wrap" wx:else>
    <view class="card"><view class="muted">加载中...</view></view>
  </view>
</view>

