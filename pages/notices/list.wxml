<navigation-bar title="社区公告" back="{{false}}" color="black" background="#FFF"></navigation-bar>
<view class="page">
  <view class="wrap">
    <view class="row" wx:if="{{isStaff}}">
      <view class="muted">物业/管理员可发布公告</view>
      <button class="btn btn-primary" size="mini" bindtap="goManage">管理</button>
    </view>

    <view wx:if="{{!items.length}}" class="card"><view class="muted">暂无公告</view></view>

    <view wx:for="{{items}}" wx:key="_id" class="list-item" bindtap="goDetail" data-id="{{item._id}}">
      <view class="row">
        <view class="col">
          <view class="title">
            <text wx:if="{{item.pinned}}">【置顶】</text>{{item.title}}
          </view>
          <view class="muted">{{item.type}} · {{format(item.createdAt)}}</view>
        </view>
        <view class="tag" wx:if="{{item.important}}">重要</view>
      </view>
    </view>
  </view>
</view>

