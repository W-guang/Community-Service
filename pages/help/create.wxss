.wrap {
  padding: 24rpx;
}
.form {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.field {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.label {
  color: #111827;
  font-size: 28rpx;
  font-weight: 600;
}
.picker {
  padding: 18rpx 16rpx;
  border-radius: 14rpx;
  background: #f3f4f6;
  color: #111827;
}
input,
textarea {
  width: 100%;
  padding: 18rpx 16rpx;
  border-radius: 14rpx;
  background: #f3f4f6;
  box-sizing: border-box;
}
textarea {
  min-height: 180rpx;
}
.submit {
  margin-top: 8rpx;
  border-radius: 16rpx;
}

