.wrap {
  padding: 24rpx;
}
.seg {
  display: flex;
  background: #f3f4f6;
  border-radius: 16rpx;
  overflow: hidden;
}
.seg-item {
  padding: 14rpx 18rpx;
  font-size: 26rpx;
  color: #374151;
}
.seg-item.on {
  background: #ffffff;
  color: #111827;
  font-weight: 600;
}
.title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}
.meta {
  margin-top: 12rpx;
}

