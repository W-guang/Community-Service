<navigation-bar title="邻里互助" back="{{false}}" color="black" background="#FFF"></navigation-bar>
<view class="page">
  <view class="wrap">
    <view class="row">
      <view class="seg">
        <view class="seg-item {{tab==='hall'?'on':''}}" bindtap="setTab" data-tab="hall">任务大厅</view>
        <view class="seg-item {{tab==='mine'?'on':''}}" bindtap="setTab" data-tab="mine">我发布的</view>
        <view class="seg-item {{tab==='taken'?'on':''}}" bindtap="setTab" data-tab="taken">我接的</view>
      </view>
      <button class="btn btn-primary" size="mini" bindtap="goCreate">发布</button>
    </view>

    <view wx:if="{{!items.length}}" class="card"><view class="muted">暂无任务</view></view>

    <view wx:for="{{items}}" wx:key="_id" class="list-item" bindtap="goDetail" data-id="{{item._id}}">
      <view class="row">
        <view class="col">
          <view class="title">{{item.title}}</view>
          <view class="muted">{{item.content}}</view>
        </view>
        <view class="tag">{{statusText(item.status)}}</view>
      </view>
      <view class="row meta">
        <view class="muted">{{format(item.createdAt)}}</view>
        <view class="muted">悬赏：{{item.rewardPoints}} 积分</view>
      </view>
    </view>
  </view>
</view>

