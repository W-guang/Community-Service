<navigation-bar title="公告管理" back="{{true}}" color="black" background="#FFF"></navigation-bar>
<view class="page">
  <view class="wrap">
    <view class="card form">
      <view class="section-title">发布公告</view>
      <view class="field">
        <view class="label">类型</view>
        <picker mode="selector" range="{{types}}" value="{{typeIndex}}" bindchange="onPickType">
          <view class="picker">{{types[typeIndex]}}</view>
        </picker>
      </view>
      <view class="field">
        <view class="label">标题</view>
        <input placeholder="例如：停水通知" value="{{form.title}}" bindinput="onTitle" />
      </view>
      <view class="field">
        <view class="label">内容</view>
        <textarea placeholder="请输入公告内容" value="{{form.content}}" bindinput="onContent" />
      </view>
      <view class="row">
        <view class="label">置顶</view>
        <switch checked="{{form.pinned}}" bindchange="onPinned" />
      </view>
      <view class="row">
        <view class="label">重要（需要强提醒/统计）</view>
        <switch checked="{{form.important}}" bindchange="onImportant" />
      </view>
      <button class="btn-primary submit" loading="{{publishing}}" bindtap="publish">发布</button>
    </view>

    <view class="card">
      <view class="row">
        <view class="section-title">历史公告</view>
        <button size="mini" bindtap="load">刷新</button>
      </view>
      <view wx:if="{{!items.length}}" class="muted mt">暂无公告</view>
      <view wx:for="{{items}}" wx:key="_id" class="item" bindtap="goDetail" data-id="{{item._id}}">
        <view class="row">
          <view class="col">
            <view class="title"><text wx:if="{{item.pinned}}">【置顶】</text>{{item.title}}</view>
            <view class="muted">{{item.type}} · {{format(item.createdAt)}}</view>
          </view>
          <view class="tag" wx:if="{{item.important}}">重要</view>
        </view>
      </view>
    </view>
  </view>
</view>

