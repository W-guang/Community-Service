/* 提示卡片样式 */
.tip-card {
  background: linear-gradient(135deg, #eef2ff 0%, #ffffff 60%);
  border: 1rpx solid #dbeafe;
  margin-bottom: 30rpx;
}

/* 表单卡片样式 */
.form-card {
  margin-bottom: 30rpx;
}

.card-title {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.card-title .card-icon {
  font-size: 40rpx;
  margin-right: 15rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.form-content {
  display: flex;
  flex-direction: column;
}

.field {
  margin-bottom: 30rpx;
}

.label {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

input {
  width: 100%;
  height: 88rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  background: #ffffff;
  box-sizing: border-box;
  transition: all 0.2s;
}

input:focus {
  border-color: #1296db;
  box-shadow: 0 0 0 4rpx rgba(18, 150, 219, 0.1);
}

.button-group {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 40rpx;
}

.submit-btn {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
}

.secondary-btn {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  color: #64748b;
}

.btn-icon {
  margin-right: 10rpx;
  font-size: 28rpx;
}

/* 绑定记录样式 */
.item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.item:last-child {
  border-bottom: none;
}

.title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

